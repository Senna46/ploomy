# ============================================================
# Ploomy Configuration
# ============================================================

# GitHub organizations to monitor (comma-separated)
# All repos under these orgs will be scanned for labeled Issues
# Example: PLANNER_GITHUB_ORGS="my-org,another-org"
PLANNER_GITHUB_ORGS=

# Specific GitHub repos to monitor (comma-separated, format: owner/repo)
# Example: PLANNER_GITHUB_REPOS="my-org/repo-a,my-org/repo-b"
PLANNER_GITHUB_REPOS=

# Label that triggers plan generation (default: plan-request)
PLANNER_ISSUE_LABEL=plan-request

# Polling interval in seconds (default: 120)
PLANNER_POLL_INTERVAL=120

# Claude model override (optional, uses CLI default if empty)
PLANNER_CLAUDE_MODEL=

# Codex model override (default: gpt-5.3-codex)
PLANNER_CODEX_MODEL=gpt-5.3-codex

# Working directory for cloned repos (default: ~/.ploomy/repos)
PLANNER_WORK_DIR=

# SQLite database path (default: ~/.ploomy/state.db)
PLANNER_DB_PATH=

# Local plan file storage (default: ~/.ploomy/plans)
PLANNER_PLANS_DIR=

# Log level: debug, info, warn, error (default: info)
PLANNER_LOG_LEVEL=info

# ============================================================
# Authentication
# ============================================================

# GitHub token (optional if gh CLI is authenticated)
GH_TOKEN=

# Claude Code OAuth token (required on macOS Docker)
# Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Or use Anthropic API key for pay-as-you-go
ANTHROPIC_API_KEY=

# OpenAI API key for Codex CLI (if not using ChatGPT OAuth)
OPENAI_API_KEY=
